# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit real secrets.

# Required -----------------------------------------------------------------

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-5

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_HmLrGzHH_C

# Where the digest email should be delivered
DIGEST_TO_EMAIL=adityajjw19@gmail.com

# Optional -----------------------------------------------------------------

# Sender identity. Defaults to `AI Digest <onboarding@resend.dev>`, which works
# without domain verification but has lower deliverability.
# DIGEST_FROM_EMAIL=AI Digest <digest@yourdomain.com>

# Tavily web search API key — https://tavily.com (free tier = 1k searches/mo).
# Leave unset to disable Tavily and rely on RSS + Twitter only.
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# Subscriber pipeline -----------------------------------------------------
# Shared HMAC secret used to sign unsubscribe links. MUST match the value set
# in Vercel env (api/subscribe.py + api/unsubscribe.py read this too).
UNSUB_SECRET=change-me-to-a-long-random-string

# Public URL of the deployed subscription site. Used to build unsubscribe
# links in outgoing emails. Set to your Vercel domain.
PUBLIC_BASE_URL=https://your-vercel-app.vercel.app
